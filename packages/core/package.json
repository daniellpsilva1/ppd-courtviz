{
  "name": "@courtviz/core",
  "version": "0.0.0",
  "description": "Framework-agnostic tennis court geometry, scales, and data normalization",
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": ["dist"],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "lint": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist .turbo"
  },
  "dependencies": {
    "d3-array": "^3.2.4",
    "d3-contour": "^4.0.0",
    "d3-hexbin": "^0.2.2",
    "d3-interpolate": "^3.0.1",
    "d3-scale": "^4.0.2",
    "d3-shape": "^3.2.0"
  },
  "devDependencies": {
    "@types/d3-array": "^3.2.1",
    "@types/d3-contour": "^3.0.6",
    "@types/d3-hexbin": "^0.2.2",
    "@types/d3-interpolate": "^3.0.1",
    "@types/d3-scale": "^4.0.8",
    "@types/d3-shape": "^3.1.7",
    "tsup": "^8.3.5",
    "vitest": "^3.0.0"
  },
  "peerDependencies": {
    "typescript": ">=5.0.0"
  }
}
