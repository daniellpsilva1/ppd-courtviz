{
  "name": "@ppd/tokens",
  "version": "0.0.0",
  "description": "Peak Performance Data design tokens — single source of truth for brand identity",
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": ["dist", "BRAND.md"],
  "scripts": {
    "build": "tsup && node scripts/build-artifacts.mjs",
    "build:artifacts": "node scripts/build-artifacts.mjs",
    "dev": "tsup --watch",
    "lint": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist .turbo"
  },
  "devDependencies": {
    "tsup": "^8.3.5",
    "vitest": "^3.0.0"
  }
}
